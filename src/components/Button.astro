---
const {
  href = "#",
  variant = "primary", // primary | ghost | subtle
  size = "md", // sm | md | lg
  target,
  rel,
} = Astro.props;

const sizes = {
  sm: "px-3 py-2 text-xs",
  md: "px-4 py-2.5 text-sm",
  lg: "px-5 py-3 text-sm",
}[size];

const base = "inline-flex items-center justify-center rounded-xl2 font-ui font-semibold tracking-[0.12em] uppercase transition focus:outline-none focus:ring-2 focus:ring-punk-red/60 focus:ring-offset-0";
const variants = {
  primary: "bg-punk-red hover:bg-punk-redDark text-white shadow-glow",
  ghost: "bg-transparent hover:bg-white/5 text-white border border-white/10",
  subtle: "bg-white/5 hover:bg-white/10 text-white border border-white/10",
}[variant];

---
<a href={href} target={target} rel={rel} class={`${base} ${variants} ${sizes}`}>
  <slot />
</a>
