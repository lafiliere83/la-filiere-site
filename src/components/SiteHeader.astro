---
import Container from "./Container.astro";
import Logo from "./Logo.astro";
import Button from "./Button.astro";

const PODIA_URL = import.meta.env.PUBLIC_PODIA_URL || "#";
const RDV_URL = import.meta.env.PUBLIC_RDV_URL || "#";
---
<header class="fixed top-0 z-50 w-full border-b border-white/10 bg-ink-950/70 backdrop-blur">
  <Container className="flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3">
      <Logo />
      <span class="hidden md:inline font-ui text-[10px] tracking-[0.34em] uppercase text-white/50">Formation Industrie Musicale</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm text-white/75">
      <a class="hover:text-white transition" href="/parcours">Parcours</a>
      <a class="hover:text-white transition" href="/consulting">Consulting</a>
      <a class="hover:text-white transition" href="/ressources">Ressources</a>
      <a class="hover:text-white transition" href="/a-propos">À propos</a>
      <a class="hover:text-white transition" href="/contact">Contact</a>
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <Button variant="ghost" href={RDV_URL}>Prendre un RDV</Button>
      <Button variant="primary" href={PODIA_URL}>Accéder aux parcours</Button>
    </div>

    <!-- Mobile -->
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer select-none rounded-xl2 border border-white/10 bg-white/5 px-3 py-2 font-ui text-xs tracking-[0.20em] uppercase">
        Menu
      </summary>
      <div class="absolute right-0 mt-3 w-[92vw] max-w-sm rounded-xl2 border border-white/10 bg-ink-900 p-3 shadow-glow">
        <div class="grid gap-1 text-sm">
          <a class="rounded-xl2 px-3 py-2 hover:bg-white/5" href="/parcours">Parcours</a>
          <a class="rounded-xl2 px-3 py-2 hover:bg-white/5" href="/consulting">Consulting</a>
          <a class="rounded-xl2 px-3 py-2 hover:bg-white/5" href="/ressources">Ressources</a>
          <a class="rounded-xl2 px-3 py-2 hover:bg-white/5" href="/a-propos">À propos</a>
          <a class="rounded-xl2 px-3 py-2 hover:bg-white/5" href="/contact">Contact</a>
        </div>
        <div class="mt-3 grid grid-cols-2 gap-2">
          <Button variant="ghost" href={RDV_URL}>RDV</Button>
          <Button variant="primary" href={PODIA_URL}>Parcours</Button>
        </div>
      </div>
    </details>
  </Container>
</header>
