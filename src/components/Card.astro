---
const { title, eyebrow, tone = "default" } = Astro.props;
const toneClasses = tone === "accent"
  ? "border-punk-red/40 bg-gradient-to-br from-white/5 to-ink-900"
  : "border-white/10 bg-ink-900";
---
<div class={`rounded-xl2 border ${toneClasses} p-6 sm:p-7 transition hover:-translate-y-0.5 hover:border-punk-red/40 hover:shadow-glow`}>
  {eyebrow ? <div class="font-ui text-[11px] tracking-[0.32em] uppercase text-punk-red mb-3">{eyebrow}</div> : null}
  {title ? <h3 class="font-ui text-base sm:text-lg font-bold tracking-tight">{title}</h3> : null}
  <div class="mt-3 text-white/75 leading-relaxed text-sm">
    <slot />
  </div>
</div>
