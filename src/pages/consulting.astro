---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

const PODIA_URL = import.meta.env.PUBLIC_PODIA_URL || "#";
const RDV_URL = import.meta.env.PUBLIC_RDV_URL || "#";
---
<BaseLayout title="Consulting — La Filière" description="Audit et accompagnement : roadmap, deals, distribution, édition, live, admin.">
  <section>
    <Container className="py-12 sm:py-16">

<div class="max-w-3xl">
  <div class="font-ui text-[11px] tracking-[0.32em] uppercase text-punk-red">Consulting</div>
  <h1 class="mt-3 font-ui text-3xl sm:text-4xl font-extrabold tracking-tight">Un RDV. Un plan clair.</h1>
  <p class="mt-4 text-white/70 leading-relaxed">
    Format court et actionnable : audit, priorités, décisions, documents à sécuriser, et roadmap.
  </p>
  <div class="mt-6 flex gap-3 flex-wrap">
    <Button variant="primary" href={RDV_URL}>Prendre un RDV</Button>
    <Button variant="ghost" href="/contact">Poser une question</Button>
  </div>
</div>

<div class="mt-10 grid gap-5 md:grid-cols-2">
  <Card eyebrow="Exemples" title="Sujets fréquents">
    Deals label / distribution • édition & sous-édition • synchro • structuration admin • live • stratégie contenus.
  </Card>
  <Card eyebrow="Livrable" title="Ce que tu repars avec">
    Une synthèse, une liste d’actions priorisées, et les documents/points à vérifier.
  </Card>
</div>

    </Container>
  </section>
</BaseLayout>
