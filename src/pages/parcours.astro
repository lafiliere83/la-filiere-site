---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";

const PODIA_URL = import.meta.env.PUBLIC_PODIA_URL || "#";
const RDV_URL = import.meta.env.PUBLIC_RDV_URL || "#";
---

<BaseLayout title="Parcours — La Filière" description="Trois parcours, une progression logique. Offres de lancement limitées.">
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-40 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-punk-red/10 blur-3xl"></div>
    </div>

    <Container className="py-12 sm:py-16">
      <div class="max-w-3xl">
        <div class="font-ui text-[11px] tracking-[0.32em] uppercase text-punk-red">Parcours</div>
        <h1 class="mt-3 font-ui text-3xl sm:text-4xl font-extrabold tracking-tight">Choisis ton niveau.</h1>
        <p class="mt-3 text-white/70 leading-relaxed">
          Trois parcours, une progression logique. <span class="text-white/85 font-semibold">Offres de lancement limitées.</span>
          Les tarifs sont affichés ici pour être clair, et l’accès se fait via Podia.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={PODIA_URL} variant="primary">Accéder sur Podia</Button>
          <Button href={RDV_URL} variant="ghost">Prendre un RDV</Button>
        </div>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        <div class="rounded-xl2 border border-white/10 bg-white/5 p-6">
          <div class="font-ui text-[11px] tracking-[0.28em] uppercase text-white/55">Essentiel</div>
          <div class="mt-2 flex items-baseline gap-2">
            <div class="font-ui text-3xl font-extrabold">690€</div>
            <div class="text-xs text-white/50">ou 3× 250€</div>
          </div>
          <p class="mt-3 text-sm text-white/75 leading-relaxed">Comprendre la filière + sortir un projet proprement.</p>
          <ul class="mt-4 text-sm text-white/65 grid gap-2 list-disc pl-5">
            <li>M0–M4 + M6</li>
            <li>Droits, production, distribution</li>
            <li>Marketing, audience & data</li>
          </ul>
          <div class="mt-6">
            <Button href={PODIA_URL} variant="primary">Choisir Essentiel</Button>
          </div>
        </div>

        <div class="rounded-xl2 border border-punk-red/30 bg-punk-red/10 p-6 shadow-glow">
          <div class="font-ui text-[11px] tracking-[0.28em] uppercase text-punk-red">Avancé</div>
          <div class="mt-2 flex items-baseline gap-2">
            <div class="font-ui text-3xl font-extrabold">890€</div>
            <div class="text-xs text-white/50">ou 3× 320€</div>
          </div>
          <p class="mt-3 text-sm text-white/75 leading-relaxed">Développer une activité + structurer l’exécution.</p>
          <ul class="mt-4 text-sm text-white/65 grid gap-2 list-disc pl-5">
            <li>Tout Essentiel</li>
            <li>+ Live (M5)</li>
            <li>+ Admin & finances (M7)</li>
          </ul>
          <div class="mt-6">
            <Button href={PODIA_URL} variant="primary">Choisir Avancé</Button>
          </div>
        </div>

        <div class="rounded-xl2 border border-white/10 bg-white/5 p-6">
          <div class="font-ui text-[11px] tracking-[0.28em] uppercase text-white/55">Pro (complet)</div>
          <div class="mt-2 flex items-baseline gap-2">
            <div class="font-ui text-3xl font-extrabold">990€</div>
            <div class="text-xs text-white/50">ou 3× 360€</div>
          </div>
          <p class="mt-3 text-sm text-white/75 leading-relaxed">Maîtrise complète + communauté élèves.</p>
          <ul class="mt-4 text-sm text-white/65 grid gap-2 list-disc pl-5">
            <li>Tous les modules + bonus</li>
            <li>Discord privé élèves</li>
            <li>1 live mensuel collectif</li>
          </ul>
          <div class="mt-6">
            <Button href={PODIA_URL} variant="primary">Choisir Pro</Button>
          </div>
        </div>
      </div>

      <div class="mt-10 rounded-xl2 border border-white/10 bg-ink-900/40 p-6">
        <div class="grid gap-6 lg:grid-cols-12 lg:items-center">
          <div class="lg:col-span-8">
            <div class="font-ui text-[11px] tracking-[0.28em] uppercase text-white/50">Communauté élèves</div>
            <p class="mt-2 text-sm text-white/70 leading-relaxed">
              Discord privé + 1 live mensuel collectif. Accès réservé aux élèves : <span class="text-white/85 font-semibold">24€/mois</span>.
            </p>
          </div>
          <div class="lg:col-span-4 flex lg:justify-end">
            <Button href={RDV_URL} variant="ghost">Question / cas spécifique</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
