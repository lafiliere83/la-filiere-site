---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

const PODIA_URL = import.meta.env.PUBLIC_PODIA_URL || "#";
const RDV_URL = import.meta.env.PUBLIC_RDV_URL || "#";
---
<BaseLayout title="Parcours — La Filière" description="Choisis ton niveau : Fondations, Structuration, Pro.">
  <section>
    <Container className="py-12 sm:py-16">

<div class="max-w-3xl">
  <div class="font-ui text-[11px] tracking-[0.32em] uppercase text-punk-red">Parcours</div>
  <h1 class="mt-3 font-ui text-3xl sm:text-4xl font-extrabold tracking-tight">Trois niveaux. Une méthode.</h1>
  <p class="mt-4 text-white/70 leading-relaxed">
    Ici on détaille la logique des parcours. La vente et l’accès se font sur Podia.
  </p>
  <div class="mt-6 flex gap-3 flex-wrap">
    <Button variant="primary" href={PODIA_URL}>Voir sur Podia</Button>
    <Button variant="ghost" href="/#faq">Lire la FAQ</Button>
  </div>
</div>

<div class="mt-10 grid gap-5 md:grid-cols-3">
  <Card tone="accent" eyebrow="Débutant" title="Fondations">
    Cartographie de l’industrie, rôles, droits, premiers contrats, erreurs fréquentes, checklists.
  </Card>
  <Card eyebrow="Avancé" title="Structuration">
    Distribution, metadata, édition & gestion, admin, cash, process et templates.
  </Card>
  <Card eyebrow="Pro" title="Exécution & scaling">
    Négociation, international, stratégie multi-plateformes, organisation d’équipe, optimisation.
  </Card>
</div>

    </Container>
  </section>
</BaseLayout>
