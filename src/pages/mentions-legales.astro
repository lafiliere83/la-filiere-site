---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

const PODIA_URL = import.meta.env.PUBLIC_PODIA_URL || "#";
const RDV_URL = import.meta.env.PUBLIC_RDV_URL || "#";
---
<BaseLayout title="Mentions légales — La Filière" description="Mentions légales.">
  <section>
    <Container className="py-12 sm:py-16">

<div class="max-w-3xl">
  <div class="font-ui text-[11px] tracking-[0.32em] uppercase text-punk-red">Mentions légales</div>
  <h1 class="mt-3 font-ui text-3xl sm:text-4xl font-extrabold tracking-tight">À compléter.</h1>
  <p class="mt-4 text-white/70 leading-relaxed">
    Ajoute ici les informations légales (éditeur du site, hébergeur, contact, etc.).
  </p>
</div>

    </Container>
  </section>
</BaseLayout>
