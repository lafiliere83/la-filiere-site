---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

const PODIA_URL = import.meta.env.PUBLIC_PODIA_URL || "#";
const RDV_URL = import.meta.env.PUBLIC_RDV_URL || "#";
---
<BaseLayout title="Ressources — La Filière" description="Templates, checklists et outils pour avancer vite.">
  <section>
    <Container className="py-12 sm:py-16">

<div class="max-w-3xl">
  <div class="font-ui text-[11px] tracking-[0.32em] uppercase text-punk-red">Ressources</div>
  <h1 class="mt-3 font-ui text-3xl sm:text-4xl font-extrabold tracking-tight">Templates & outils.</h1>
  <p class="mt-4 text-white/70 leading-relaxed">
    Ici tu pourras regrouper checklists, modèles et articles. (On peut ensuite brancher une newsletter.)
  </p>
</div>

<div class="mt-10 grid gap-5 md:grid-cols-3">
  <Card eyebrow="Template" title="Feuille de splits">
    Version simple + version pro, avec rappels droits/édition.
  </Card>
  <Card eyebrow="Checklist" title="Sortie & livraison">
    Les points qui font perdre du temps (ou de l’argent) si tu les loupes.
  </Card>
  <Card eyebrow="Outil" title="Mini-glossaire">
    Définitions terrain pour arrêter de subir le jargon.
  </Card>
</div>

    </Container>
  </section>
</BaseLayout>
