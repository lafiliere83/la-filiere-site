---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

const PODIA_URL = import.meta.env.PUBLIC_PODIA_URL || "#";
const RDV_URL = import.meta.env.PUBLIC_RDV_URL || "#";
---
<BaseLayout title="Contact — La Filière" description="Contact et demandes : formation, consulting, partenariats.">
  <section>
    <Container className="py-12 sm:py-16">

<div class="max-w-3xl">
  <div class="font-ui text-[11px] tracking-[0.32em] uppercase text-punk-red">Contact</div>
  <h1 class="mt-3 font-ui text-3xl sm:text-4xl font-extrabold tracking-tight">On échange.</h1>
  <p class="mt-4 text-white/70 leading-relaxed">
    Pour une question, une demande presse/partenariat, ou du consulting.
  </p>
</div>

<div class="mt-10 grid gap-5 md:grid-cols-2">
  <Card eyebrow="Email" title="Contact direct">
    Ajoute ton email ici : <span class="text-white/90">contact@lafiliere.fr</span> (à remplacer)
  </Card>
  <Card eyebrow="Formulaire" title="Demande rapide">
    <form class="mt-2 grid gap-3">
      <input class="rounded-xl2 border border-white/10 bg-white/5 px-4 py-3 text-sm outline-none focus:border-punk-red/60" placeholder="Nom" />
      <input class="rounded-xl2 border border-white/10 bg-white/5 px-4 py-3 text-sm outline-none focus:border-punk-red/60" placeholder="Email" />
      <textarea class="min-h-[120px] rounded-xl2 border border-white/10 bg-white/5 px-4 py-3 text-sm outline-none focus:border-punk-red/60" placeholder="Message"></textarea>
      <button type="button" class="rounded-xl2 bg-punk-red px-4 py-3 font-ui text-xs tracking-[0.20em] uppercase font-semibold hover:bg-punk-redDark">
        Envoyer (à connecter)
      </button>
      <p class="text-xs text-white/40">Le formulaire est volontairement non-connecté (statique). On peut le brancher à Brevo/Formspree ensuite.</p>
    </form>
  </Card>
</div>

    </Container>
  </section>
</BaseLayout>
