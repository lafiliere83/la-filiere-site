---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

const PODIA_URL = import.meta.env.PUBLIC_PODIA_URL || "#";
const RDV_URL = import.meta.env.PUBLIC_RDV_URL || "#";
---
<BaseLayout title="À propos — La Filière" description="La Filière : une approche terrain, structurée, orientée exécution.">
  <section>
    <Container className="py-12 sm:py-16">

<div class="max-w-3xl">
  <div class="font-ui text-[11px] tracking-[0.32em] uppercase text-punk-red">À propos</div>
  <h1 class="mt-3 font-ui text-3xl sm:text-4xl font-extrabold tracking-tight">La Filière, c’est une carte et une méthode.</h1>
  <p class="mt-4 text-white/70 leading-relaxed">
    Le but : rendre lisible l’industrie musicale et donner des outils concrets pour décider et exécuter.
    “By Otake” = une approche entrepreneuriale, orientée résultats, avec une vraie compréhension des deals.
  </p>
</div>

<div class="mt-10 grid gap-5 md:grid-cols-2">
  <Card eyebrow="Principe" title="Clarté > complexité">
    On simplifie sans déformer : tu comprends les règles, puis tu choisis une stratégie adaptée à ton cas.
  </Card>
  <Card eyebrow="Promesse" title="Action immédiate">
    À chaque concept, une action. À chaque action, un document, un risque, et une décision.
  </Card>
</div>

    </Container>
  </section>
</BaseLayout>
